PORT=3000

# PostgreSQL — Railway provides this automatically when you add a Postgres service
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# Google OAuth Client ID (from console.cloud.google.com)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
